<div class="h-full overflow-y-auto">
  <div class="max-w-2xl mx-auto p-8">
    <% if notice = flash[:notice] %>
      <p class="py-2 px-3 bg-green-50 dark:bg-green-950 mb-5 text-green-600 dark:text-green-400 text-sm font-medium rounded-lg"><%= notice %></p>
    <% end %>

    <h1 class="font-bold text-2xl mb-8">Account settings</h1>

    <%= form_with model: @user, url: account_path, class: "space-y-6" do |form| %>
      <div>
        <%= form.label :email_address, class: "block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1" %>
        <%= form.email_field :email_address, disabled: true, class: "block w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-stone-100 dark:bg-stone-800 px-3 py-2.5 text-sm text-stone-500" %>
      </div>

      <div>
        <%= form.label :display_name, class: "block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1" %>
        <%= form.text_field :display_name, placeholder: "How should we address you?", class: "form-select block w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100" %>
      </div>

      <div>
        <%= form.label :default_corpus_slug, "Default corpus", class: "block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1" %>
        <%= form.select :default_corpus_slug, Corpus.pluck(:name, :slug), { include_blank: "None" }, class: "form-select block w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100" %>
      </div>

      <div>
        <%= form.label :default_translation_abbreviation, "Default translation", class: "block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1" %>
        <%= form.select :default_translation_abbreviation, Translation.pluck(:name, :abbreviation), { include_blank: "None" }, class: "form-select block w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100" %>
      </div>

      <div>
        <%= form.label :language, class: "block text-sm font-medium text-stone-700 dark:text-stone-300 mb-1" %>
        <%= form.select :language, [["English", "en"], ["Arabic (العربية)", "ar"], ["Hebrew (עברית)", "he"]], {}, class: "form-select block w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100" %>
      </div>

      <%= form.submit "Save settings", class: "rounded-lg px-4 py-2.5 bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 text-sm font-medium cursor-pointer hover:bg-stone-800 dark:hover:bg-stone-200 transition-colors" %>
    <% end %>

    <hr class="my-10 border-stone-200 dark:border-stone-800">

    <h2 class="font-bold text-lg mb-4">Passkeys</h2>
    <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">Sign in with Face ID, Touch ID, or a hardware security key.</p>

    <% if @passkey_credentials.any? %>
      <ul class="space-y-2 mb-4">
        <% @passkey_credentials.each do |cred| %>
          <li class="flex items-center justify-between p-3 rounded-lg border border-stone-200 dark:border-stone-800">
            <div>
              <span class="text-sm font-medium"><%= cred.label || "Passkey" %></span>
              <span class="text-xs text-stone-400 ml-2">Added <%= time_ago_in_words(cred.created_at) %> ago</span>
            </div>
            <%= button_to "Remove", passkey_credential_path(cred), method: :delete, class: "text-xs text-red-600 dark:text-red-400 hover:underline", data: { turbo_confirm: "Remove this passkey?" } %>
          </li>
        <% end %>
      </ul>
    <% end %>

    <button id="register-passkey"
            data-controller="passkey-register"
            data-action="click->passkey-register#register"
            class="rounded-lg px-4 py-2.5 border border-stone-300 dark:border-stone-700 text-sm font-medium hover:bg-stone-50 dark:hover:bg-stone-900 transition-colors">
      Add a passkey
    </button>

    <hr class="my-10 border-stone-200 dark:border-stone-800">

    <div>
      <%= button_to "Sign out", session_path, method: :delete, class: "text-sm text-red-600 dark:text-red-400 hover:underline" %>
    </div>
  </div>
</div>
