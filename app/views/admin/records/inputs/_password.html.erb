<%# locals: (form:, field_name:, css_class: "", required: false) %>

<div data-controller="password password-generator"
     class="<%= class_names("record-edit__password-field", css_class) %>"
     data-action="password-generator:updateToggleIconEvent->password#updateToggleIconEvent"
     data-password-generator-copied-label-value="<%= t('admin.labels.copied', default: 'Copied!') %>"
     data-password-show-password-label-value="<%= t('admin.labels.show_password', default: 'Show password') %>"
     data-password-hide-password-label-value="<%= t('admin.labels.hide_password', default: 'Hide password') %>">
  <div class="record-edit__password-input-wrapper">
    <%= form.password_field field_name,
        class: "record-edit__field-input form-input record-edit__password-input",
        autocomplete: "off",
        data: { password_target: "field", password_generator_target: "field" },
        required: %>

    <button type="button"
            class="record-edit__password-toggle"
            data-password-target="toggleButton"
            data-password-generator-target="toggleButton"
            data-action="click->password#togglePasswordVisibility"
            title="<%= t("admin.labels.show_password", default: "Show password") %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-password-target="eyeIcon">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 11-4.243-4.243m4.242 4.242L9.88 9.88"/>
      </svg>
    </button>
  </div>

  <div class="record-edit__password-actions">
    <button type="button"
            class="btn btn--small btn--secondary record-edit__password-button"
            data-password-generator-target="generateButton"
            data-action="click->password-generator#generatePassword">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/>
      </svg>
      <%= t("admin.labels.generate_password", default: "Generate Password") %>
    </button>

    <button type="button"
            class="btn btn--small btn--secondary record-edit__password-button"
            data-password-generator-target="copyButton"
            data-action="click->password-generator#copyPassword">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <%= t("admin.labels.copy", default: "Copy") %>
    </button>
  </div>

  <% if form.object.persisted? %>
    <div class="record-edit__field-hint">
      <p class="record-edit__field-hint-text"><%= t("admin.labels.leave_blank_for_current_password", default: "Leave blank to keep current password") %></p>
    </div>
  <% end %>
</div>
