<%= form_with model: group, class: "space-y-4 max-w-lg" do |f| %>
  <% if group.errors.any? %>
    <div class="p-3 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 text-sm">
      <% group.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100", placeholder: "e.g. NT Source Criticism Seminar" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-900 dark:focus:ring-stone-100", placeholder: "What is this group about?" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :public, class: "rounded border-stone-300 dark:border-stone-700" %>
    <%= f.label :public, "Public group (anyone can view)", class: "text-sm" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit group.persisted? ? "Update" : "Create", class: "rounded-lg px-4 py-2 bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 text-sm font-medium cursor-pointer hover:bg-stone-800 dark:hover:bg-stone-200 transition-colors" %>
    <%= link_to "Cancel", group.persisted? ? group_path(group) : groups_path, class: "text-sm text-stone-500 hover:text-stone-900 dark:hover:text-stone-100 transition-colors" %>
  </div>
<% end %>
