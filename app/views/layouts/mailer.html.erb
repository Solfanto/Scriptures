<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>

  <body style="margin: 0; padding: 0; background-color: #fafaf9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #fafaf9; padding: 40px 0;">
      <tr>
        <td align="center">
          <table width="480" cellpadding="0" cellspacing="0" style="max-width: 480px; width: 100%;">
            <%# Header %>
            <tr>
              <td style="padding: 0 24px 24px;">
                <table cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="width: 32px; height: 32px; background-color: #1c1917; border-radius: 8px; text-align: center; vertical-align: middle;">
                      <span style="color: #ffffff; font-weight: bold; font-size: 16px; line-height: 32px;">S</span>
                    </td>
                    <td style="padding-left: 10px; font-weight: bold; font-size: 16px; color: #1c1917; letter-spacing: -0.025em;">Scriptures</td>
                  </tr>
                </table>
              </td>
            </tr>
            <%# Body %>
            <tr>
              <td style="background-color: #ffffff; border: 1px solid #e7e5e4; border-radius: 16px; padding: 32px 28px;">
                <%= yield %>
              </td>
            </tr>
            <%# Footer %>
            <tr>
              <td style="padding: 24px; text-align: center;">
                <p style="margin: 0; font-size: 11px; color: #a8a29e;">Scriptures — a study tool for comparative religion scholars</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
