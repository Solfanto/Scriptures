<p style="margin: 0 0 16px; font-size: 15px; color: #1c1917; line-height: 1.6;">Hi<%= @user.display_name ? " #{@user.display_name}" : "" %>,</p>

<p style="margin: 0 0 8px; font-size: 13px; color: #78716c; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Your sign-in code</p>

<div style="background-color: #fafaf9; border: 1px solid #e7e5e4; border-radius: 12px; padding: 20px; text-align: center; margin: 0 0 20px;">
  <span style="font-size: 36px; font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace; font-weight: 700; letter-spacing: 0.2em; color: #1c1917;"><%= @short_code %></span>
</div>

<p style="margin: 0 0 24px; font-size: 14px; color: #57534e; line-height: 1.6;">Enter this code in the browser where you requested it. It expires in 15 minutes.</p>

<table cellpadding="0" cellspacing="0" style="margin: 0 0 20px;">
  <tr><td style="height: 1px; background-color: #e7e5e4; font-size: 0; line-height: 0;" colspan="3">&nbsp;</td></tr>
  <tr><td style="height: 16px;" colspan="3"></td></tr>
</table>

<p style="margin: 0 0 16px; font-size: 14px; color: #57534e; line-height: 1.6;">Or sign in from any browser:</p>

<table cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td align="center">
      <a href="<%= @url %>" style="display: inline-block; background-color: #1c1917; color: #ffffff; font-size: 14px; font-weight: 500; padding: 10px 24px; border-radius: 10px; text-decoration: none;">Sign in with link</a>
    </td>
  </tr>
</table>

<p style="margin: 24px 0 0; font-size: 12px; color: #a8a29e; line-height: 1.5;">If you didn't request this, you can safely ignore this email.</p>
